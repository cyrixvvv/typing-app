<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools">

    <!-- No internet permission needed - all content is local -->

    <uses-feature
        android:name="android.hardware.touchscreen"
        android:required="false" />
    <uses-feature
        android:name="android.software.leanback"
        android:required="true" />
    <uses-feature
        android:name="android.hardware.remotePON"
        android:required="false" />

    <application
        android:allowBackup="true"
        android:icon="@android:drawable/ic_dialog_dialer"
        android:label="@string/app_name"
        android:supportsRtl="true"
        android:theme="@style/Theme.HongluTyping"
        android:largeHeap="true">

        <!-- Main entry activity -->
        <activity
            android:name=".MainActivity"
            android:exported="true"
            android:screenOrientation="landscape"
            android:resizeableActivity="false"
            android:launchMode="singleTask">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
                <category android:name="android.intent.category.LEANBACK_LAUNCHER" />
            </intent-filter>
        </activity>

        <!-- Primary mode (指法训练) -->
        <activity
            android:name=".main.PrimaryModeActivity"
            android:exported="false"
            android:screenOrientation="landscape"
            android:configChanges="orientation|screenSize|keyboardHidden" />

        <!-- Advanced mode (WPM测试) -->
        <activity
            android:name=".main.AdvancedModeActivity"
            android:exported="false"
            android:screenOrientation="landscape"
            android:configChanges="orientation|screenSize|keyboardHidden" />

        <!-- Content selection (LeanBack) -->
        <activity
            android:name=".main.ContentSelectActivity"
            android:exported="false"
            android:screenOrientation="landscape" />

        <!-- Settings activity -->
        <activity
            android:name=".main.SettingsActivity"
            android:exported="false"
            android:screenOrientation="landscape" />

    </application>
</manifest>

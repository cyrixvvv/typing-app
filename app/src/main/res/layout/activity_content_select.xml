<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/bg_primary"
    android:padding="24dp">

    <!-- Title bar -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingBottom="16dp">

        <TextView
            android:id="@+id/tv_back"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/common_back"
            android:textColor="@color/text_primary"
            android:textSize="20sp"
            android:padding="8dp" />

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="@string/menu_content"
            android:textColor="@color/text_primary"
            android:textSize="28sp"
            android:textStyle="bold"
            android:gravity="center" />

        <View android:layout_width="48dp" android:layout_height="1dp" />
    </LinearLayout>

    <!-- English section -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingBottom="24dp">

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="ENGLISH"
            android:textColor="@color/accent"
            android:textSize="18sp"
            android:textStyle="bold"
            android:paddingTop="8dp"
            android:paddingBottom="8dp" />

        <TextView
            android:id="@+id/tv_random_en"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="▶ 英文随机（循环练习）"
            android:textColor="@color/color_gold"
            android:textSize="22sp"
            android:gravity="center"
            android:padding="16dp"
            android:focusable="true"
            android:clickable="true"
            android:background="@color/bg_key"
            android:layout_marginBottom="8dp" />

        <LinearLayout
            android:id="@+id/en_container"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal" />
    </LinearLayout>

    <!-- Chinese section -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="中文"
            android:textColor="@color/accent"
            android:textSize="18sp"
            android:textStyle="bold"
            android:paddingTop="8dp"
            android:paddingBottom="8dp" />

        <TextView
            android:id="@+id/tv_random_cn"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="▶ 中文随机（循环练习）"
            android:textColor="@color/color_gold"
            android:textSize="22sp"
            android:gravity="center"
            android:padding="16dp"
            android:focusable="true"
            android:clickable="true"
            android:background="@color/bg_key"
            android:layout_marginBottom="8dp" />

        <LinearLayout
            android:id="@+id/cn_container"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal" />
    </LinearLayout>

</LinearLayout>

<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/bg_primary"
    android:padding="@dimen/padding_standard">

    <!-- Top bar: back + title -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical">

        <TextView
            android:id="@+id/tv_back"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/advanced_back"
            android:textColor="@color/text_secondary"
            android:textSize="@dimen/text_size_hint"
            android:padding="12dp"
            android:clickable="true"
            android:focusable="true"
            android:background="?android:attr/selectableItemBackground" />

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="@string/menu_advanced"
            android:textColor="@color/text_primary"
            android:textSize="@dimen/text_size_primary"
            android:textStyle="bold"
            android:gravity="center" />

        <View android:layout_width="60dp" android:layout_height="1dp" />
    </LinearLayout>

    <!-- Content mode selector tabs -->
    <HorizontalScrollView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:paddingBottom="8dp"
        android:fillViewport="true">

        <LinearLayout
            android:id="@+id/mode_selector"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center">

            <TextView
                android:id="@+id/tv_mode_en"
                android:layout_width="80dp"
                android:layout_height="40dp"
                android:text="英文"
                android:textColor="@color/color_gold"
                android:textSize="@dimen/text_size_hint"
                android:gravity="center"
                android:focusable="true"
                android:clickable="true"
                android:background="@drawable/selector_tab_active" />

            <View android:layout_width="4dp" android:layout_height="1dp" />

            <TextView
                android:id="@+id/tv_mode_en_num"
                android:layout_width="100dp"
                android:layout_height="40dp"
                android:text="英数"
                android:textColor="@color/text_secondary"
                android:textSize="@dimen/text_size_hint"
                android:gravity="center"
                android:focusable="true"
                android:clickable="true"
                android:background="@drawable/selector_tab_inactive" />

            <View android:layout_width="4dp" android:layout_height="1dp" />

            <TextView
                android:id="@+id/tv_mode_mixed"
                android:layout_width="80dp"
                android:layout_height="40dp"
                android:text="大小写"
                android:textColor="@color/text_secondary"
                android:textSize="@dimen/text_size_hint"
                android:gravity="center"
                android:focusable="true"
                android:clickable="true"
                android:background="@drawable/selector_tab_inactive" />

            <View android:layout_width="4dp" android:layout_height="1dp" />

            <TextView
                android:id="@+id/tv_mode_cn"
                android:layout_width="80dp"
                android:layout_height="40dp"
                android:text="中文"
                android:textColor="@color/text_secondary"
                android:textSize="@dimen/text_size_hint"
                android:gravity="center"
                android:focusable="true"
                android:clickable="true"
                android:background="@drawable/selector_tab_inactive" />
        </LinearLayout>
    </HorizontalScrollView>

    <!-- Stats bar: WPM, CPM, 正确率, 得分, 总分 -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center"
        android:paddingTop="4dp"
        android:paddingBottom="4dp">

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical"
            android:gravity="center">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/advanced_wpm"
                android:textStyle="bold"
                android:textColor="@color/accent"
                android:textSize="@dimen/text_size_stats" />

            <TextView
                android:id="@+id/tv_wpm_value"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="0"
                android:textColor="@color/text_primary"
                android:textSize="@dimen/text_size_primary"
                android:textStyle="bold" />
        </LinearLayout>

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical"
            android:gravity="center">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/advanced_cpm"
                android:textStyle="bold"
                android:textColor="@color/accent"
                android:textSize="@dimen/text_size_stats" />

            <TextView
                android:id="@+id/tv_cpm_value"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="0"
                android:textColor="@color/text_primary"
                android:textSize="@dimen/text_size_primary"
                android:textStyle="bold" />
        </LinearLayout>

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical"
            android:gravity="center">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/advanced_accuracy"
                android:textStyle="bold"
                android:textColor="@color/color_correct"
                android:textSize="@dimen/text_size_stats" />

            <TextView
                android:id="@+id/tv_accuracy_value"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="0%"
                android:textColor="@color/text_primary"
                android:textSize="@dimen/text_size_primary"
                android:textStyle="bold" />
        </LinearLayout>

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical"
            android:gravity="center">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/advanced_score"
                android:textStyle="bold"
                android:textColor="@color/color_gold"
                android:textSize="@dimen/text_size_stats" />

            <TextView
                android:id="@+id/tv_score_value"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="0"
                android:textColor="@color/text_primary"
                android:textSize="@dimen/text_size_primary"
                android:textStyle="bold" />
        </LinearLayout>

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical"
            android:gravity="center">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/advanced_total"
                android:textStyle="bold"
                android:textColor="@color/color_gold"
                android:textSize="@dimen/text_size_stats" />

            <TextView
                android:id="@+id/tv_total_score_value"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="0"
                android:textColor="@color/text_primary"
                android:textSize="@dimen/text_size_primary"
                android:textStyle="bold" />
        </LinearLayout>
    </LinearLayout>

    <!-- Progress bar -->
    <ProgressBar
        android:id="@+id/pb_progress"
        style="?android:attr/progressBarStyleHorizontal"
        android:layout_width="match_parent"
        android:layout_height="4dp"
        android:progressTint="@color/color_progress"
        android:progressBackgroundTint="@color/bg_key"
        android:max="100"
        android:progress="0" />

    <!-- Multi-line text display (wraps naturally, no scrolling) -->
    <TextView
        android:id="@+id/tv_display_text"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:textColor="@color/text_primary"
        android:textSize="42sp"
        android:gravity="center_vertical"
        android:lineSpacingExtra="8dp"
        android:padding="12dp"
        android:text="准备就绪" />

    <!-- Hint area at bottom -->
    <TextView
        android:id="@+id/tv_hint"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="@string/primary_hint"
        android:textColor="@color/text_hint"
        android:textSize="@dimen/text_size_hint"
        android:gravity="center"
        android:padding="4dp" />

</LinearLayout>

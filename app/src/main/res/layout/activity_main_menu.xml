<?xml version="1.0" encoding="utf-8"?>
<!-- Main menu layout: compact grid for TV, all 4 buttons visible on 1080p -->
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/bg_primary"
    android:gravity="center"
    android:padding="32dp">

    <!-- App title -->
    <TextView
        android:id="@+id/tv_title"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="@string/app_name"
        android:textColor="@color/text_primary"
        android:textSize="48sp"
        android:textStyle="bold"
        android:paddingTop="24dp"
        android:layout_marginBottom="32dp" />

    <!-- Menu buttons -->
    <Button
        android:id="@+id/btn_primary"
        android:layout_width="360dp"
        android:layout_height="64dp"
        android:text="@string/menu_primary"
        android:textSize="28sp"
        android:layout_marginBottom="16dp" />

    <Button
        android:id="@+id/btn_advanced"
        android:layout_width="360dp"
        android:layout_height="64dp"
        android:text="@string/menu_advanced"
        android:textSize="28sp"
        android:layout_marginBottom="16dp" />

    <Button
        android:id="@+id/btn_content"
        android:layout_width="360dp"
        android:layout_height="64dp"
        android:text="@string/menu_content"
        android:textSize="28sp"
        android:layout_marginBottom="16dp" />

    <Button
        android:id="@+id/btn_settings"
        android:layout_width="360dp"
        android:layout_height="64dp"
        android:text="@string/menu_settings"
        android:textSize="28sp"
        android:backgroundTint="@color/bg_key" />

</LinearLayout>

<?xml version="1.0" encoding="utf-8"?>
<resources>
    <style name="Theme.HongluTyping" parent="Theme.AppCompat">
        <item name="colorPrimary">@color/accent</item>
        <item name="colorPrimaryDark">@color/bg_primary</item>
        <item name="colorAccent">@color/accent</item>
    </style>

    <!-- Keyboard key text styles -->
    <style name="KeyLabel" parent="@android:style/TextAppearance.Medium">
        <item name="android:textColor">@color/text_primary</item>
        <item name="android:textSize">@dimen/text_size_primary</item>
        <item name="android:textStyle">bold</item>
        <item name="android:gravity">center</item>
    </style>

    <!-- Encouragement text -->
    <style name="EncourageText" parent="@android:style/TextAppearance.Large">
        <item name="android:textColor">@color/color_gold</item>
        <item name="android:textSize">@dimen/encourage_text_size</item>
        <item name="android:textStyle">bold</item>
        <item name="android:gravity">center</item>
    </style>

    <!-- Stat label -->
    <style name="StatLabel" parent="@android:style/TextAppearance.Medium">
        <item name="android:textColor">@color/text_secondary</item>
        <item name="android:textSize">@dimen/text_size_stats</item>
    </style>

    <!-- Stat value -->
    <style name="StatValue" parent="@android:style/TextAppearance.Large">
        <item name="android:textColor">@color/text_primary</item>
        <item name="android:textSize">@dimen/text_size_primary</item>
        <item name="android:textStyle">bold</item>
    </style>
</resources>
